{
  "name": "KawaiiYumee",
  "version": "2.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/src dist/router && cp -r src/*.json src/*.jpg dist/src/ 2>/dev/null || true && cp -r public dist/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "dev:watch": "nodemon --exec ts-node index.ts",
    "pm2": "pm2 start index.ts --name KawaiiYumee --interpreter node --node-args=\"-r ts-node/register\" && pm2 save"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "axios-cookiejar-support": "^5.0.2",
    "cheerio": "^1.0.0",
    "playwright": "^1.58.2",
    "moment-timezone": "^0.6.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "got": "^14.6.6",
    "crypto-js": "^4.2.0",
    "express": "^4.21.2",
    "file-type": "^16.5.4",
    "form-data": "^4.0.2",
    "jimp": "^0.22.10",
    "canvas": "^3.2.1",
    "multer": "^1.4.5-lts.2",
    "tough-cookie": "^5.1.2",
    "@faker-js/faker": "^9.9.0",
    "@pm2/io": "^6.1.0",
    "canvafy": "^7.2.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "ejs": "^3.1.10",
    "fluent-ffmpeg": "^2.1.3",
    "html-entities": "^2.6.0",
    "jimp-esm": "^1.6.0",
    "jsqr": "^1.4.0",
    "needle": "^3.3.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "playwright-core": "^1.58.2",
    "puppeteer": "^24.12.1",
    "puppeteer-core": "^24.12.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "qs": "^6.14.0",
    "randomstring": "^1.3.1",
    "sharp": "^0.34.3",
    "user-agents": "^1.1.607",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^5.0.1",
    "@types/form-data": "^2.5.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/tough-cookie": "^4.0.5",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "@types/randomstring": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
